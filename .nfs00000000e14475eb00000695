import bpy
import math
from pathlib import Path
from mathutils import Vector

AX_LIMS = 0.4

model_file = '/home/rcannon/Code/Radar/SHAPE/2000rs11/PS2/FF/modfiles/FF.obj'

# Reset to empty scene
bpy.ops.wm.read_factory_settings(use_empty=True)
scene = bpy.context.scene

# -------------------------
# Import OBJ
# -------------------------
bpy.ops.wm.obj_import(filepath=model_file)
obj = bpy.context.selected_objects[0]

# Center object
bpy.context.view_layer.objects.active = obj
bpy.ops.object.origin_set(type='ORIGIN_GEOMETRY', center='BOUNDS')
obj.location = (0, 0, 0)

# -------------------------
# Camera
# -------------------------
cam_data = bpy.data.cameras.new("Camera")
cam_data.type = 'ORTHO'

cam_obj = bpy.data.objects.new("Camera", cam_data)
scene.collection.objects.link(cam_obj)
scene.camera = cam_obj

# Position camera safely away
cam_obj.location = (0, -AX_LIMS*2, 0)
cam_obj.rotation_euler = (math.radians(90), 0, 0)

# -------------------------
# Light
# -------------------------
light_data = bpy.data.lights.new(name="Light", type='SUN')
light_obj = bpy.data.objects.new(name="Light", object_data=light_data)
scene.collection.objects.link(light_obj)
light_obj.rotation_euler = cam_obj.rotation_euler.copy()

# -------------------------
# Create shiny material
# -------------------------
mat = bpy.data.materials.new(name="SpecMaterial")
mat.use_nodes = True

nodes = mat.node_tree.nodes
links = mat.node_tree.links

# Clear default nodes
nodes.clear()

# Create nodes
output = nodes.new(type="ShaderNodeOutputMaterial")
bsdf = nodes.new(type="ShaderNodeBsdfPrincipled")

links.new(bsdf.outputs["BSDF"], output.inputs["Surface"])

# Material settings (Blender 4)
bsdf.inputs["Base Color"].default_value = (0.1, 0.1, 0.1, 1)
bsdf.inputs["Specular IOR Level"].default_value = 0.2
bsdf.inputs["Roughness"].default_value = 0.01  # lower = shinier

# Assign material
obj.data.materials.clear()
obj.data.materials.append(mat)

# -------------------------
# White background WITHOUT lighting
# -------------------------

# Create world
world = bpy.data.worlds.new("NoLightWorld")
scene.world = world
world.use_nodes = True

nodes = world.node_tree.nodes
links = world.node_tree.links
nodes.clear()

bg = nodes.new(type="ShaderNodeBackground")
bg.inputs["Color"].default_value = (0, 0, 0, 1)
bg.inputs["Strength"].default_value = 0.0  # ZERO light

output = nodes.new(type="ShaderNodeOutputWorld")
links.new(bg.outputs["Background"], output.inputs["Surface"])

# Enable transparent render
scene.render.film_transparent = True

scene.use_nodes = True
tree = scene.node_tree
nodes = tree.nodes
links = tree.links

nodes.clear()

render_layers = nodes.new(type='CompositorNodeRLayers')
alpha_over = nodes.new(type='CompositorNodeAlphaOver')
composite = nodes.new(type='CompositorNodeComposite')

# White background
alpha_over.inputs[1].default_value = (1, 1, 1, 1)

links.new(render_layers.outputs['Image'], alpha_over.inputs[2])
links.new(alpha_over.outputs['Image'], composite.inputs['Image'])

# -------------------------
# Render settings
# -------------------------
scene.render.engine = 'CYCLES'
scene.render.resolution_x = 1920
scene.render.resolution_y = 1080
scene.render.filepath = "render.png"

# Adjust ortho scale to fit object
bbox = [obj.matrix_world @ Vector(corner) for corner in obj.bound_box]
max_dim = max((v.length for v in bbox))
cam_data.ortho_scale = max_dim * 2.2

# -------------------------
# Render
# -------------------------
bpy.ops.render.render(write_still=True)